{
  "name": "missevan-counter",
  "version": "1.3.2",
  "description": "M&M Toolkit for Missevan and Manbo statistics.",
  "author": "M&M Toolkit",
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server.js",
    "desktop": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "lucide-react": "^0.542.0",
    "node-fetch": "^3.3.2",
    "radix-ui": "^1.4.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.13",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.missevan.toolkit.desktop",
    "productName": "M&M Toolkit",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.js",
      "manboIndexStore.js",
      "envConfig.js",
      "shared/**/*",
      "data/**/*",
      "package.json"
    ],
    "win": {
      "icon": "windowsapp.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "artifactName": "M&M-Toolkit-${version}-${arch}.exe"
    }
  }
}
